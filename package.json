{
  "name": "dci-learning-academy",
  "version": "0.0.0",
  "private": true,
  "description": "DCI Learning Academy — unified portal and lab modules for DCI students",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @dci/portal dev",
    "build": "pnpm -r --filter \"./apps/*\" build",
    "smoke": "pnpm build && node scripts/smoke-serve.mjs",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "rebrand": "tsx scripts/rebrand.ts",
    "generate:catalog": "node scripts/generate-lab-catalog.mjs",
    "deploy:rules": "npx -y firebase-tools@latest deploy --only firestore:rules"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "fast-glob": "^3.3.2",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@firebase/util",
      "protobufjs"
    ]
  }
}
